MAS miners {
    // Environment 12 (Semiramis) explicitly selected
    environment: env.MiningEnvironment(12, 100, yes, "world12killer", "dummy", 1000)

    agents:
        // red team
        world12killer world12killer.asl 
             agentClass agent.SelectEvent
             beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)","committed_to(_,_,key)")
             agentArchClass arch.LocalMinerArch
             #6;

        // blue team
        dummy dummy.asl 
              agentArchClass arch.LocalMinerArch 
              #6;

    aslSourcePath: "asl";
}