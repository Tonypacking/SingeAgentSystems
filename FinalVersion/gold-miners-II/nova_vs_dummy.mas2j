MAS miners {
    environment: env.MiningEnvironment(12, 100, yes, "nova", "dummy", 1000)

    agents:
        // red team — nova strategy (1 leader + 6 miners)
        novaldr novaleader.asl
                beliefBaseClass agent.DiscardBelsBB("cell","pos","carrying_gold")
                ;

        nova1 nova.asl
              agentClass agent.SelectEvent
              beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)")
              agentArchClass arch.LocalMinerArch;
        nova2 nova.asl
              agentClass agent.SelectEvent
              beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)")
              agentArchClass arch.LocalMinerArch;
        nova3 nova.asl
              agentClass agent.SelectEvent
              beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)")
              agentArchClass arch.LocalMinerArch;
        nova4 nova.asl
              agentClass agent.SelectEvent
              beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)")
              agentArchClass arch.LocalMinerArch;
        nova5 nova.asl
              agentClass agent.SelectEvent
              beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)")
              agentArchClass arch.LocalMinerArch;
        nova6 nova.asl
              agentClass agent.SelectEvent
              beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)")
              agentArchClass arch.LocalMinerArch;

        // blue team — dummy opponent
        dummy agentArchClass arch.LocalMinerArch #6;

    aslSourcePath: "asl";
}
